{
  "manifest_version": 3,
  "name": "Tab Hopper",
  "description": "Tab Hopper makes switching between tabs faster and easier.",
  "version": "2.7",
  "permissions": [
    "scripting", 
    "activeTab", 
    "tabs", 
    "storage"
  ],
  "icons": {
    "16": "Icon.png",
    "48": "Icon.png",
    "128": "Icon.png"

  },
  "action": {
    "default_title": "Open Modal"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module",
    "persistant": true
  },
  "host_permissions": [
        "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["modal.css"],
      "run_at": "document_idle"
    }
  ]
}
